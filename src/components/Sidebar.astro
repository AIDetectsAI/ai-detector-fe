---
import { Upload, Clock, Cog, User } from 'lucide-react';
import '../styles/global.css';
import '../styles/sidebar.css';

const iconMap = {
  upload: Upload,
  clock: Clock,
  cog: Cog,
};

const navItems = [
  { label: 'Upload', path: '/send', icon: 'upload' },
  { label: 'Analysis History', path: '/history', icon: 'clock' },
  { label: 'Settings', path: '/options', icon: 'cog' },
];
---

<aside class="sidebar w-1/6 flex flex-col justify-between min-h-screen text-white">
  <div class="flex flex-col items-center mt-4">
    <div class="flex items-center justify-center text-3xl font-bold h-20 mb-8">
      ajajaj detector
    </div>
    
    <nav class="w-full">
      <ul class="space-y-2 px-4">
        {navItems.map((item) => {
          const Icon = iconMap[item.icon as keyof typeof iconMap];
          return (
            <li>
              <button
                onclick={`location.href='${item.path}'`}
                class="flex items-center gap-2 justify-center px-4 py-3 hover:bg-blue-800 text-lg rounded w-full"
              >
                <Icon className="w-5 h-5" />
                {item.label}
              </button>
            </li>
          );
        })}
      </ul>
    </nav>

    <ul class="space-y-3 list-none p-2 w-full">
      {navItems.map((item) => {
        const Icon = iconMap[item.icon as keyof typeof iconMap];
        return (
          <li class="">
            <button
              onclick={`location.href='${item.path}'`}
              class="medium-btn sidebar-btn text-lg w-full px-4 py-3 gap-2"
            >
              <Icon className="w-5 h-5" />
              {item.label}
            </button>
          </li>
        );
      })}
    </ul>
  </div>

  <div class="p-2 w-full">
    <button
      onclick="location.href='/'"
      class="sidebar-btn text-lg w-full"
    >
      <User className="w-6 h-6 border-2 border-white rounded-full p-0.5" />
      User
    </button>
  </div>
</aside>